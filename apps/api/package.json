{
  "name": "@app/api",
  "version": "2.0.0",
  "description": "NestJS API - AI-Powered Customer Support Ticket System",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:cov": "vitest --coverage",
    "test:e2e": "vitest --config ./test/vitest-e2e.config.ts",
    "sdk:export": "node scripts/export-openapi.mjs",
    "typeorm": "ts-node --project tsconfig.json -r dotenv/config node_modules/typeorm/cli.js",
    "migration:run": "ts-node --project tsconfig.json -r dotenv/config node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:generate": "ts-node --project tsconfig.json -r dotenv/config node_modules/typeorm/cli.js migration:generate -d src/database/data-source.ts",
    "migration:create": "ts-node --project tsconfig.json node_modules/typeorm/cli.js migration:create",
    "migration:revert": "ts-node --project tsconfig.json -r dotenv/config node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "seed": "ts-node --project tsconfig.json -r dotenv/config src/database/seeds/seed.ts",
    "db:init": "pnpm migration:run && pnpm seed"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.0",
    "@nestjs/bull": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@pkg/types": "workspace:*",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.40.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.0.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "orval": "^7.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0"
  }
}
